# Copy to .env and adjust. DATABASE_URL is required.

# PostgreSQL (recommended). Use +psycopg2 for the synchronous driver.
DATABASE_URL=postgresql+psycopg2://freshsave:freshsave@localhost:5432/freshsave

# Optional: local file DB (set DATABASE_URL only; no extra flags needed)
# DATABASE_URL=sqlite:///./freshsave.db

# Connection pool (PostgreSQL)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# Set true to log SQL statements (verbose)
DB_ECHO_SQL=false

# Run SELECT 1 on app startup; set false if the DB is not up during import tooling
DB_VALIDATE_ON_STARTUP=true
